@system.command('resources')
def system_resources():
    """Show detailed resource usage"""
    # TODO: Implement resource monitoring
    import psutil
    
    console.print("[bold]System Resources[/bold]\n")
    
    # CPU
    cpu_percent = psutil.cpu_percent(interval=1, percpu=True)
    console.print("[bold cyan]CPU Usage:[/bold cyan]")
    for i, usage in enumerate(cpu_percent):
        console.print(f"Core {i}: [yellow]{usage}%[/yellow]")
    
    # Memory
    mem = psutil.virtual_memory()
    console.print(f"\n[bold cyan]Memory:[/bold cyan]")
    console.print(f"Total: {mem.total / (1024**3):.1f} GB")
    console.print(f"Used: [yellow]{mem.used / (1024**3):.1f} GB ({mem.percent}%)[/yellow]")
    console.print(f"Available: {mem.available / (1024**3):.1f} GB")
    
    # Disk
    disk = psutil.disk_usage('/var/lib/forge-train')
    console.print(f"\n[bold cyan]Disk (/var/lib/forge-train):[/bold cyan]")
    console.print(f"Total: {disk.total / (1024**3):.1f} GB")
    console.print(f"Used: [yellow]{disk.used / (1024**3):.1f} GB ({disk.percent}%)[/yellow]")
    console.print(f"Free: {disk.free / (1024**3):.1f} GB")


